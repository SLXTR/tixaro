<% layout('layout') -%>
<header class="workbench-heading">
  <div><h1>Kunden</h1><p>Unternehmen und Ansprechpartner verwalten.</p></div>
</header>

<div class="admin-grid crm-layout">
  <section class="panel panel-wide">
    <div class="panel-header"><div><h2>Unternehmen</h2></div></div>
    <% if (customers.length) { %>
      <div class="customer-grid">
        <% customers.forEach(customer => { %>
          <a class="customer-card" href="/customers/<%= customer.id %>">
            <span class="company-avatar"><%= initials(customer.name) %></span>
            <div class="customer-card-main">
              <div class="customer-card-title"><strong><%= customer.name %></strong><span class="status-pill status-<%= customer.status %>"><%= customerStatusLabel(customer.status) %></span></div>
              <small><%= customer.customer_number %><%= customer.domain ? ` · @${customer.domain}` : '' %><%= customer.industry ? ` · ${customer.industry}` : '' %></small>
              <div class="customer-card-stats">
                <span><b><%= customer.contact_count %></b> Kontakte</span>
                <span><b><%= customer.asset_count %></b> Ressourcen</span>
                <span><b><%= customer.ticket_count %></b> Tickets</span>
              </div>
            </div>
            <span class="card-arrow">→</span>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state"><span>–</span><h3>Noch keine Kunden</h3><p>Lege rechts den ersten CRM-Eintrag an.</p></div>
    <% } %>
  </section>

  <aside class="panel form-panel">
    <div class="panel-header"><div><h2>Unternehmen anlegen</h2></div></div>
    <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
    <form class="stack-form" action="/customers" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Firmenname<input type="text" name="name" value="<%= values.name || '' %>" minlength="2" required autofocus></label>
      <label>Branche<input type="text" name="industry" value="<%= values.industry || '' %>" placeholder="z. B. Steuerberatung"></label>
      <label>Firmendomain<input type="text" name="domain" value="<%= values.domain || '' %>" placeholder="beispiel.de" inputmode="url" required><small>Kundenbenutzer mit dieser E-Mail-Domain werden automatisch zugeordnet.</small></label>
      <label>Telefon<input type="tel" name="phone" value="<%= values.phone || '' %>"></label>
      <div class="address-autocomplete" data-address-autocomplete>
        <label>Adresse<input type="text" name="address" value="<%= values.address || '' %>" autocomplete="street-address" placeholder="Straße und Hausnummer" data-address-input></label>
        <input type="hidden" name="latitude" value="<%= values.latitude || '' %>" data-latitude-input>
        <input type="hidden" name="longitude" value="<%= values.longitude || '' %>" data-longitude-input>
        <div class="address-suggestion-list" role="listbox" data-address-results hidden></div>
        <small>Adressvorschläge auf Basis von OpenStreetMap und Photon.</small>
      </div>
      <label>Ort<input type="text" name="city" value="<%= values.city || '' %>" autocomplete="address-level2" data-city-input></label>
      <label>Status<select name="status"><% customerStatuses.forEach(value => { %><option value="<%= value %>" <%= (values.status || 'active') === value ? 'selected' : '' %>><%= customerStatusLabel(value) %></option><% }) %></select></label>
      <button class="button button-primary button-full" type="submit">Unternehmen anlegen</button>
    </form>
  </aside>
</div>
