<% layout('layout') -%>
<div class="ticket-heading">
  <div>
    <div class="ticket-kicker"><a href="/customers">CRM</a><span>/</span><strong><%= customer.customer_number %></strong></div>
    <h1><%= customer.name %></h1>
    <div class="ticket-heading-meta"><span class="status-pill status-<%= customer.status %>"><%= customerStatusLabel(customer.status) %></span><span><%= customer.domain ? `@${customer.domain}` : 'Keine Domain' %></span><% if (customer.city) { %><span><%= customer.city %></span><% } %></div>
  </div>
  <div class="ticket-heading-actions"><a class="button button-primary" href="/tickets/new">Ticket erstellen</a><a class="button button-secondary" href="/customers">Zurück</a></div>
</div>

<div class="customer-detail-grid">
  <div class="customer-main-column">
    <% if (customer.address) { %>
      <section class="panel customer-map-panel">
        <div class="panel-header">
          <div><p class="panel-kicker">Kundenstandort</p><h2><%= customer.address %><%= customer.city ? `, ${customer.city}` : '' %></h2></div>
          <% if (mapExternalUrl) { %><a href="<%= mapExternalUrl %>" target="_blank" rel="noopener noreferrer">Große Karte öffnen ↗</a><% } %>
        </div>
        <% if (mapEmbedUrl) { %>
          <div class="customer-map-frame"><iframe src="<%= mapEmbedUrl %>" title="Kartenstandort von <%= customer.name %>" loading="lazy" referrerpolicy="no-referrer"></iframe></div>
          <div class="map-attribution">Kartendaten © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener noreferrer">OpenStreetMap-Mitwirkende</a></div>
        <% } else { %>
          <div class="map-placeholder"><span>⌖</span><div><strong>Standort noch nicht positioniert</strong><p>Wähle die Adresse in den Vorschlägen aus oder speichere die Stammdaten erneut.</p></div></div>
        <% } %>
      </section>
    <% } %>

    <section class="panel" id="contacts">
      <div class="panel-header"><div><h2>Kontakte</h2></div></div>
      <% if (contacts.length) { %>
        <div class="contact-list">
          <% contacts.forEach(contact => { %>
            <article class="contact-row">
              <span class="avatar avatar-soft"><%= initials(contact.name) %></span>
              <div class="contact-identity"><strong><%= contact.name %></strong><span><%= contact.job_title || contact.department || roleLabel(contact.role) %> · <%= contact.email %></span></div>
              <span class="contact-state <%= contact.active ? 'is-active' : '' %>"><%= contact.active ? 'Aktiv' : 'Inaktiv' %></span>
            </article>
          <% }) %>
        </div>
      <% } else { %><div class="empty-state compact-empty"><span>○</span><h3>Noch keine Ansprechpartner</h3><p>Ordne einen bestehenden Benutzer zu oder lege einen Kundenbenutzer an.</p></div><% } %>
    </section>

    <section class="panel">
      <div class="panel-header"><div><h2>Ressourcen</h2></div><a href="/assets/new">Ressource anlegen</a></div>
      <% if (assets.length) { %>
        <div class="asset-list compact-asset-list">
          <% assets.forEach(asset => { %>
            <a class="asset-row" href="/assets/<%= asset.id %>">
              <span class="asset-icon"><%= asset.asset_type === 'Notebook' ? 'NB' : asset.asset_type === 'Computer' ? 'PC' : asset.asset_type === 'Softwarelizenz' ? 'SW' : 'IT' %></span>
              <span class="asset-identity"><strong><%= asset.name %></strong><small><%= asset.asset_number %> · <%= asset.asset_type %></small></span>
              <span><%= asset.assigned_user_name || 'Nicht zugewiesen' %></span>
              <span class="asset-status asset-status-<%= asset.status %>"><%= assetStatusLabel(asset.status) %></span>
              <span class="card-arrow">→</span>
            </a>
          <% }) %>
        </div>
      <% } else { %><div class="empty-state compact-empty"><span>–</span><h3>Keine Ressourcen</h3><p>Geräte und Verträge werden später direkt in Tickets sichtbar.</p></div><% } %>
    </section>

    <section class="panel">
      <div class="panel-header"><div><h2>Ticketverlauf</h2></div></div>
      <%- include('../partials/ticket-table', { tickets }) %>
    </section>
  </div>

  <aside class="customer-side-column">
    <form class="panel form-panel" action="/customers/<%= customer.id %>/update" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="panel-header"><div><h2>Kundendaten</h2></div></div>
      <label>Firmenname<input type="text" name="name" value="<%= customer.name %>" required></label>
      <label>Domain<input type="text" name="domain" value="<%= customer.domain || '' %>" placeholder="beispiel.de" inputmode="url" required><small>Wird für die automatische Benutzerzuordnung verwendet.</small></label>
      <label>Status<select name="status"><% customerStatuses.forEach(value => { %><option value="<%= value %>" <%= customer.status === value ? 'selected' : '' %>><%= customerStatusLabel(value) %></option><% }) %></select></label>
      <details class="form-disclosure"><summary>Kontakt und Adresse</summary><div class="stack-form">
        <label>Branche<input type="text" name="industry" value="<%= customer.industry || '' %>"></label>
        <label>Telefon<input type="tel" name="phone" value="<%= customer.phone || '' %>"></label>
        <label>Website<input type="url" name="website" value="<%= customer.website || '' %>" placeholder="https://"></label>
        <div class="address-autocomplete" data-address-autocomplete>
          <label>Adresse<input type="text" name="address" value="<%= customer.address || '' %>" autocomplete="street-address" data-address-input></label>
          <input type="hidden" name="latitude" value="<%= customer.latitude || '' %>" data-latitude-input><input type="hidden" name="longitude" value="<%= customer.longitude || '' %>" data-longitude-input>
          <div class="address-suggestion-list" role="listbox" data-address-results hidden></div>
        </div>
        <label>Ort<input type="text" name="city" value="<%= customer.city || '' %>" autocomplete="address-level2" data-city-input></label>
        <label>Notizen<textarea name="notes" rows="4"><%= customer.notes || '' %></textarea></label>
      </div></details>
      <button class="button button-primary button-full" type="submit">Speichern</button>
    </form>

    <% if (can('customers.manage') && assignableContacts.length) { %>
      <form class="panel form-panel" action="/customers/<%= customer.id %>/contacts/assign" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="panel-header"><div><h2>Benutzer zuordnen</h2></div></div>
        <label>Benutzer<select name="user_id" required><option value="">Bitte auswählen</option><% assignableContacts.forEach(contact => { %><option value="<%= contact.id %>"><%= contact.name %> · <%= contact.email %><%= contact.current_customer_name ? ` · bisher ${contact.current_customer_name}` : '' %></option><% }) %></select></label>
        <button class="button button-secondary button-full" type="submit">Zuordnen</button>
      </form>
    <% } %>

    <form class="panel form-panel" action="/customers/<%= customer.id %>/contacts" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="panel-header"><div><h2>Kontakt anlegen</h2></div></div>
      <div class="form-grid"><label>Vorname<input type="text" name="first_name" minlength="2" required></label><label>Nachname<input type="text" name="last_name" minlength="2" required></label></div>
      <label>E-Mail<input type="email" name="email" required></label>
      <label>Startpasswort<input type="password" name="password" minlength="10" autocomplete="new-password" required><small>Mindestens 10 Zeichen</small></label>
      <details class="form-disclosure"><summary>Weitere Angaben</summary><div class="stack-form"><label>Position<input type="text" name="job_title"></label><label>Abteilung<input type="text" name="department"></label><label>Telefon<input type="tel" name="phone"></label><label>Standort<input type="text" name="site"></label></div></details>
      <button class="button button-secondary button-full" type="submit">Anlegen</button>
    </form>
  </aside>
</div>
