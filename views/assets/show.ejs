<% layout('layout') -%>
<div class="ticket-heading">
  <div>
    <div class="ticket-kicker"><a href="/assets">Ressourcen</a><span>/</span><strong><%= asset.asset_number %></strong></div>
    <h1><%= asset.name %></h1>
    <div class="ticket-heading-meta"><span class="asset-status asset-status-<%= asset.status %>"><%= assetStatusLabel(asset.status) %></span><span><%= asset.asset_type %></span><span><%= asset.manufacturer || '' %> <%= asset.model || '' %></span></div>
  </div>
  <div class="ticket-heading-actions"><a class="button button-primary" href="/tickets/new">Ticket erstellen</a><a class="button button-secondary" href="/assets">← Ressourcen</a></div>
</div>

<div class="asset-detail-grid">
  <div class="asset-main-column">
    <section class="asset-hero panel">
      <div class="asset-hero-icon"><%= asset.asset_type === 'Notebook' ? 'NB' : asset.asset_type === 'Computer' ? 'PC' : asset.asset_type === 'Smartphone' ? 'SP' : 'IT' %></div>
      <div class="asset-hero-copy"><p class="eyebrow"><%= asset.asset_type %></p><h2><%= asset.manufacturer || 'Unbekannter Hersteller' %> <%= asset.model || '' %></h2><p><%= asset.serial_number ? `Seriennummer ${asset.serial_number}` : 'Keine Seriennummer hinterlegt' %></p></div>
      <dl>
        <div><dt>Kunde</dt><dd><%= asset.customer_name || 'Nicht zugeordnet' %></dd></div>
        <div><dt>Kundenbenutzer</dt><dd><%= asset.assigned_user_name || 'Nicht zugewiesen' %></dd></div>
        <div><dt>Standort</dt><dd><%= asset.location || '–' %></dd></div>
        <div><dt>Garantie</dt><dd class="warranty-<%= warrantyState(asset.warranty_until) %>"><%= formatDate(asset.warranty_until) %></dd></div>
      </dl>
    </section>

    <section class="panel specification-panel">
      <div class="panel-header"><div><h2>Technische Daten</h2></div></div>
      <dl class="spec-grid">
        <div><dt>Betriebssystem</dt><dd><%= asset.operating_system || '–' %></dd></div>
        <div><dt>CPU</dt><dd><%= asset.attributes?.cpu || '–' %></dd></div>
        <div><dt>Arbeitsspeicher</dt><dd><%= asset.attributes?.memory || '–' %></dd></div>
        <div><dt>IP-Adresse</dt><dd><%= asset.attributes?.ip_address || '–' %></dd></div>
        <div><dt>MAC-Adresse</dt><dd><%= asset.attributes?.mac_address || '–' %></dd></div>
        <div><dt>Kaufdatum</dt><dd><%= formatDate(asset.purchase_date) %></dd></div>
      </dl>
      <% if (asset.notes) { %><div class="asset-notes"><strong>Interne Notizen</strong><p><%= asset.notes %></p></div><% } %>
    </section>

    <% if (can('assets.manage')) { %>
      <section class="panel">
        <div class="panel-header"><div><p class="panel-kicker">Revisionsverlauf</p><h2>Zuordnungshistorie</h2><p>Kunde, Benutzer, Standort und Status im zeitlichen Verlauf.</p></div><% if (can('statistics.view')) { %><a href="/statistics#bestand">Stichtag prüfen</a><% } %></div>
        <% if (assignmentHistory.length) { %>
          <div class="assignment-timeline">
            <% assignmentHistory.forEach((entry, index) => { %>
              <article class="assignment-entry <%= index === 0 && !entry.valid_until ? 'is-current' : '' %>">
                <span class="assignment-marker"></span>
                <div class="assignment-period"><strong><%= formatDateTime(entry.valid_from) %></strong><small><%= entry.valid_until ? `bis ${formatDateTime(entry.valid_until)}` : 'aktuell gültig' %></small></div>
                <div class="assignment-details">
                  <strong><%= entry.customer_name || 'Ohne Kunde' %></strong>
                  <span><%= entry.assigned_user_name || 'Nicht zugewiesen' %> · <%= entry.location || 'Kein Standort' %></span>
                </div>
                <span class="asset-status asset-status-<%= entry.asset_status %>"><%= assetStatusLabel(entry.asset_status) %></span>
                <small class="assignment-author"><%= entry.changed_by_name ? `geändert von ${entry.changed_by_name}` : 'Bestandsübernahme' %></small>
              </article>
            <% }) %>
          </div>
        <% } else { %><div class="empty-state compact-empty"><span>–</span><h3>Noch kein Verlauf</h3><p>Der erste Eintrag entsteht bei einer Zuordnungsänderung.</p></div><% } %>
      </section>
    <% } %>

    <section class="panel">
      <div class="panel-header"><div><h2>Ticketverlauf</h2></div></div>
      <%- include('../partials/ticket-table', { tickets }) %>
    </section>
  </div>

  <% if (can('assets.manage')) { %>
    <aside>
      <form class="panel form-panel" action="/assets/<%= asset.id %>/update" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="panel-header"><div><h2>Ressource bearbeiten</h2></div></div>
        <label>Bezeichnung<input type="text" name="name" value="<%= asset.name %>" required></label>
        <label>Typ<select name="asset_type"><% assetTypes.forEach(value => { %><option value="<%= value %>" <%= asset.asset_type === value ? 'selected' : '' %>><%= value %></option><% }) %></select></label>
        <label>Status<select name="status"><% assetStatuses.forEach(value => { %><option value="<%= value %>" <%= asset.status === value ? 'selected' : '' %>><%= assetStatusLabel(value) %></option><% }) %></select></label>
        <label>Kunde<select name="customer_id" data-customer-select><option value="">Kein Kunde</option><% customers.forEach(customer => { %><option value="<%= customer.id %>" <%= asset.customer_id === customer.id ? 'selected' : '' %>><%= customer.name %></option><% }) %></select></label>
        <label>Kundenbenutzer<select name="assigned_user_id" data-contact-select><option value="">Nicht zugewiesen</option><% contacts.forEach(contact => { %><option value="<%= contact.id %>" data-customer-id="<%= contact.customer_id %>" <%= asset.assigned_user_id === contact.id ? 'selected' : '' %>><%= contact.name %> · <%= contact.customer_name %></option><% }) %></select></label>
        <label>Hersteller<input type="text" name="manufacturer" value="<%= asset.manufacturer || '' %>"></label>
        <label>Modell<input type="text" name="model" value="<%= asset.model || '' %>"></label>
        <label>Seriennummer<input type="text" name="serial_number" value="<%= asset.serial_number || '' %>"></label>
        <label>Betriebssystem<input type="text" name="operating_system" value="<%= asset.operating_system || '' %>"></label>
        <label>CPU<input type="text" name="cpu" value="<%= asset.attributes?.cpu || '' %>"></label>
        <label>Arbeitsspeicher<input type="text" name="memory" value="<%= asset.attributes?.memory || '' %>"></label>
        <label>IP-Adresse<input type="text" name="ip_address" value="<%= asset.attributes?.ip_address || '' %>"></label>
        <label>MAC-Adresse<input type="text" name="mac_address" value="<%= asset.attributes?.mac_address || '' %>"></label>
        <label>Standort<input type="text" name="location" value="<%= asset.location || '' %>"></label>
        <label>Kaufdatum<input type="date" name="purchase_date" value="<%= asset.purchase_date ? new Date(asset.purchase_date).toISOString().slice(0,10) : '' %>"></label>
        <label>Garantie bis<input type="date" name="warranty_until" value="<%= asset.warranty_until ? new Date(asset.warranty_until).toISOString().slice(0,10) : '' %>"></label>
        <label>Notizen<textarea name="notes" rows="4"><%= asset.notes || '' %></textarea></label>
        <button class="button button-primary button-full" type="submit">Ressource aktualisieren</button>
      </form>
    </aside>
  <% } %>
</div>
