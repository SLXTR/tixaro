<% layout('layout') -%>
<div class="page-heading compact-heading"><div><h1>Mein Konto</h1></div></div>
<div class="account-grid">
  <section class="panel profile-card"><span class="avatar avatar-xl"><%= initials(currentUser.name) %></span><h2><%= currentUser.name %></h2><p><%= currentUser.email %></p><span class="role-pill role-<%= currentUser.role %>"><%= roleLabel(currentUser.role) %></span><dl><div><dt>Mitglied seit</dt><dd><%= formatDate(currentUser.created_at) %></dd></div></dl></section>
  <div class="account-forms">
    <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
    <form class="panel form-panel stack-form" action="/account/profile" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="panel-header"><div><h2>Profil</h2></div></div><div class="form-grid"><label>Vorname<input type="text" name="first_name" value="<%= currentUser.first_name %>" minlength="2" required></label><label>Nachname<input type="text" name="last_name" value="<%= currentUser.last_name %>" minlength="2" required></label></div><label>E-Mail<input type="email" value="<%= currentUser.email %>" disabled></label><button class="button button-primary" type="submit">Speichern</button></form>
    <form class="panel form-panel stack-form" action="/account/password" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="panel-header"><div><h2>Passwort ändern</h2></div></div><label>Aktuelles Passwort<input type="password" name="current_password" autocomplete="current-password" required></label><label>Neues Passwort<input type="password" name="new_password" minlength="10" autocomplete="new-password" required></label><button class="button button-secondary" type="submit">Passwort aktualisieren</button></form>
  </div>
</div>
