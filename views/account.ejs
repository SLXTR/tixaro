<% layout('layout') -%>
<div class="page-heading compact-heading"><div><p class="eyebrow">Persönlicher Bereich</p><h1>Mein Konto</h1><p>Profildaten und Passwort verwalten.</p></div></div>
<div class="account-grid">
  <section class="panel profile-card"><span class="avatar avatar-xl"><%= initials(currentUser.name) %></span><h2><%= currentUser.name %></h2><p><%= currentUser.email %></p><span class="role-pill role-<%= currentUser.role %>"><%= roleLabel(currentUser.role) %></span><dl><div><dt>Mitglied seit</dt><dd><%= formatDate(currentUser.created_at) %></dd></div><div><dt>Status</dt><dd><span class="online-dot"></span> Aktiv</dd></div></dl></section>
  <div class="account-forms">
    <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
    <form class="panel form-panel stack-form" action="/account/profile" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="panel-header"><div><h2>Profil</h2><p>So wirst du im System angezeigt.</p></div></div><label>Anzeigename<input type="text" name="name" value="<%= currentUser.name %>" required></label><label>E-Mail-Adresse<input type="email" value="<%= currentUser.email %>" disabled><small>Die E-Mail-Adresse kann nur ein Administrator ändern.</small></label><button class="button button-primary" type="submit">Profil speichern</button></form>
    <form class="panel form-panel stack-form" action="/account/password" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><div class="panel-header"><div><h2>Passwort ändern</h2><p>Verwende mindestens 10 Zeichen.</p></div></div><label>Aktuelles Passwort<input type="password" name="current_password" autocomplete="current-password" required></label><label>Neues Passwort<input type="password" name="new_password" minlength="10" autocomplete="new-password" required></label><button class="button button-secondary" type="submit">Passwort aktualisieren</button></form>
  </div>
</div>
