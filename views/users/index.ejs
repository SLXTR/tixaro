<% layout('layout') -%>
<div class="page-heading compact-heading">
  <div><h1>Benutzer</h1></div>
</div>

<div class="admin-grid">
  <section class="panel panel-wide">
    <div class="user-list">
      <% users.forEach(user => { %>
        <article class="user-row <%= user.active ? '' : 'is-muted' %>">
          <span class="avatar avatar-soft"><%= initials(user.name) %></span>
          <div class="user-identity"><strong><%= user.name %></strong><span><%= user.email %><%= user.customer_name ? ` · ${user.customer_name}` : '' %></span></div>
          <span class="role-pill role-<%= user.role %>"><%= roleLabel(user.role) %></span>
          <% if (user.role !== 'admin' || can('users.grant_admin')) { %><a class="button button-small button-secondary" href="/users/<%= user.id %>/edit">Bearbeiten</a><% } else { %><span></span><% } %>
          <form action="/users/<%= user.id %>/toggle" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="button button-small <%= user.active ? 'button-danger-soft' : 'button-secondary' %>" type="submit" <%= user.id === currentUser.id || (user.role === 'admin' && !can('users.grant_admin')) ? 'disabled' : '' %>><%= user.active ? 'Deaktivieren' : 'Aktivieren' %></button>
          </form>
        </article>
      <% }) %>
    </div>
  </section>
  <aside class="panel form-panel">
    <div class="panel-header"><div><h2>Benutzer anlegen</h2></div></div>
    <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
    <form class="stack-form" action="/users" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-grid"><label>Vorname<input type="text" name="first_name" value="<%= values.first_name || '' %>" minlength="2" required></label><label>Nachname<input type="text" name="last_name" value="<%= values.last_name || '' %>" minlength="2" required></label></div>
      <label>E-Mail<input type="email" name="email" value="<%= values.email || '' %>" required></label>
      <label>Rolle<select name="role"><% roleOptions.forEach(role => { %><option value="<%= role %>" <%= (values.role || 'requester') === role ? 'selected' : '' %>><%= roleLabel(role) %></option><% }) %></select></label>
      <label>Kunde<select name="customer_id"><option value="">Über E-Mail-Domain zuordnen</option><% customers.forEach(customer => { %><option value="<%= customer.id %>" <%= String(values.customer_id || '') === String(customer.id) ? 'selected' : '' %>><%= customer.name %> · @<%= customer.domain %></option><% }) %></select></label>
      <label>Startpasswort<input type="password" name="password" minlength="10" autocomplete="new-password" required><small>Mindestens 10 Zeichen</small></label>
      <button class="button button-primary button-full" type="submit">Anlegen</button>
    </form>
  </aside>
</div>
