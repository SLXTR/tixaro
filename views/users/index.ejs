<% layout('layout') -%>
<div class="page-heading compact-heading">
  <div><p class="eyebrow">Administration</p><h1>Benutzerverwaltung</h1><p>Konten, Rollen und Zugänge zentral verwalten.</p></div>
</div>

<div class="admin-grid">
  <section class="panel panel-wide">
    <div class="panel-header"><div><h2>Alle Benutzer</h2><p><%= users.length %> Konten im System</p></div></div>
    <div class="user-list">
      <% users.forEach(user => { %>
        <article class="user-row <%= user.active ? '' : 'is-muted' %>">
          <span class="avatar avatar-soft"><%= initials(user.name) %></span>
          <div class="user-identity"><strong><%= user.name %></strong><span><%= user.email %></span></div>
          <span class="role-pill role-<%= user.role %>"><%= roleLabel(user.role) %></span>
          <div class="user-stat"><strong><%= user.assigned_tickets || 0 %></strong><span>aktive Tickets</span></div>
          <div class="user-stat"><strong><%= user.last_login_at ? formatDate(user.last_login_at) : '–' %></strong><span>letzte Anmeldung</span></div>
          <form action="/users/<%= user.id %>/toggle" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="button button-small <%= user.active ? 'button-danger-soft' : 'button-secondary' %>" type="submit" <%= user.id === currentUser.id ? 'disabled' : '' %>><%= user.active ? 'Deaktivieren' : 'Aktivieren' %></button>
          </form>
        </article>
      <% }) %>
    </div>
  </section>
  <aside class="panel form-panel">
    <div class="panel-header"><div><h2>Neues Konto</h2><p>Zugang für ein Teammitglied anlegen</p></div></div>
    <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
    <form class="stack-form" action="/users" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label>Name<input type="text" name="name" value="<%= values.name || '' %>" required></label>
      <label>E-Mail-Adresse<input type="email" name="email" value="<%= values.email || '' %>" required></label>
      <label>Rolle<select name="role"><option value="requester">Anfragende Person</option><option value="agent">Mitarbeiter</option><option value="admin">Administrator</option></select></label>
      <label>Startpasswort<input type="password" name="password" minlength="10" autocomplete="new-password" required><small>Mindestens 10 Zeichen. Sicher übermitteln.</small></label>
      <button class="button button-primary button-full" type="submit">Konto anlegen</button>
    </form>
  </aside>
</div>
