<% layout('layout') -%>
<div class="page-heading compact-heading">
  <div><h1>Benutzerverwaltung</h1></div>
</div>

<div class="admin-grid">
  <section class="panel panel-wide">
    <div class="panel-header"><div><h2>Benutzer</h2></div></div>
    <div class="user-list">
      <% users.forEach(user => { %>
        <article class="user-row <%= user.active ? '' : 'is-muted' %>">
          <span class="avatar avatar-soft"><%= initials(user.name) %></span>
          <div class="user-identity"><strong><%= user.name %></strong><span><%= user.email %><%= user.customer_name ? ` · ${user.customer_name}` : '' %></span></div>
          <span class="role-pill role-<%= user.role %>"><%= roleLabel(user.role) %></span>
          <div class="user-stat"><strong><%= user.assigned_tickets || 0 %></strong><span>aktive Tickets</span></div>
          <div class="user-stat"><strong><%= user.last_login_at ? formatDate(user.last_login_at) : '–' %></strong><span>letzte Anmeldung</span></div>
          <a class="button button-small button-secondary" href="/users/<%= user.id %>/edit">Bearbeiten</a>
          <form action="/users/<%= user.id %>/toggle" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="button button-small <%= user.active ? 'button-danger-soft' : 'button-secondary' %>" type="submit" <%= user.id === currentUser.id ? 'disabled' : '' %>><%= user.active ? 'Deaktivieren' : 'Aktivieren' %></button>
          </form>
        </article>
      <% }) %>
    </div>
  </section>
  <aside class="panel form-panel">
    <div class="panel-header"><div><h2>Neues Konto</h2></div></div>
    <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
    <form class="stack-form" action="/users" method="post">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-grid"><label>Vorname<input type="text" name="first_name" value="<%= values.first_name || '' %>" minlength="2" required></label><label>Nachname<input type="text" name="last_name" value="<%= values.last_name || '' %>" minlength="2" required></label></div>
      <label>E-Mail-Adresse<input type="email" name="email" value="<%= values.email || '' %>" required><small>Kundenbenutzer werden über eine eindeutige Firmendomain automatisch zugeordnet.</small></label>
      <label>Rolle<select name="role"><option value="requester">Kundenbenutzer</option><option value="agent">Mitarbeiter</option><option value="admin">Administrator</option></select></label>
      <label>Kunde <small>optional</small><select name="customer_id"><option value="">Automatisch über E-Mail-Domain</option><% customers.forEach(customer => { %><option value="<%= customer.id %>" <%= String(values.customer_id || '') === String(customer.id) ? 'selected' : '' %>><%= customer.name %> · @<%= customer.domain %></option><% }) %></select><small>Nur für Kundenbenutzer; eine Auswahl überschreibt das automatische Matching.</small></label>
      <label>Startpasswort<input type="password" name="password" minlength="10" autocomplete="new-password" required><small>Mindestens 10 Zeichen. Sicher übermitteln.</small></label>
      <button class="button button-primary button-full" type="submit">Konto anlegen</button>
    </form>
  </aside>
</div>
