<% layout('layout') -%>
<header class="workbench-heading">
  <div><h1>Benutzer bearbeiten</h1><p><%= editedUser.name %> · <%= editedUser.email %></p></div>
  <div class="workbench-actions">
    <% if (currentUser.role === 'admin' && editedUser.role === 'requester' && editedUser.active) { %>
      <form action="/users/<%= editedUser.id %>/preview" method="post"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="button button-secondary" type="submit">Portal als Benutzer ansehen</button></form>
    <% } %>
    <a class="button button-secondary" href="/users">Abbrechen</a>
  </div>
</header>

<section class="panel form-panel user-edit-panel">
  <div class="panel-header"><div><h2>Kontodaten</h2><% if (editedUser.customer_name) { %><p>Zugeordnet zu <%= editedUser.customer_name %></p><% } %></div></div>
  <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
  <form class="stack-form" action="/users/<%= editedUser.id %>/update" method="post">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="form-grid">
      <label>Vorname<input name="first_name" value="<%= values.first_name || '' %>" minlength="2" maxlength="80" required autofocus></label>
      <label>Nachname<input name="last_name" value="<%= values.last_name || '' %>" minlength="2" maxlength="80" required></label>
      <label>E-Mail-Adresse<input type="email" name="email" value="<%= values.email || '' %>" required></label>
      <label>Rolle<select name="role" <%= editedUser.id === currentUser.id ? 'disabled' : '' %>><% roles.forEach(role => { %><option value="<%= role %>" <%= values.role === role ? 'selected' : '' %>><%= roleLabel(role) %></option><% }) %></select><% if (editedUser.id === currentUser.id) { %><small>Die eigene Rolle kann hier nicht geändert werden.</small><input type="hidden" name="role" value="<%= editedUser.role %>"><% } %></label>
      <label class="field-full">Neues Passwort <small>optional</small><input type="password" name="password" minlength="10" autocomplete="new-password"><small>Leer lassen, um das bestehende Passwort beizubehalten.</small></label>
    </div>
    <div><button class="button button-primary" type="submit">Änderungen speichern</button></div>
  </form>
</section>
