<% layout('layout') -%>
<% if (currentUser.role === 'requester') { %>
<header class="workbench-heading portal-list-heading">
  <div><h1>Neue Anfrage</h1></div>
  <a class="button button-secondary" href="/tickets">Zurück</a>
</header>
<form class="portal-request-form" action="/tickets" method="post">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <section class="panel form-panel">
    <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
    <div class="portal-request-fields">
      <label>Betreff<input type="text" name="subject" value="<%= values.subject || '' %>" minlength="4" maxlength="180" placeholder="z. B. Anmeldung funktioniert nicht" required autofocus></label>
      <label>Beschreibung<textarea name="description" rows="9" minlength="10" placeholder="Was ist passiert? Seit wann besteht das Problem? Gibt es eine Fehlermeldung?" required><%= values.description || '' %></textarea><small>Bitte keine Passwörter oder Zugangsdaten eintragen.</small></label>
      <label>Gerät <small>optional</small>
        <select name="asset_id" data-ticket-asset data-default-requester="<%= currentUser.id %>"><option value="">Kein bestimmtes Gerät</option><% assets.forEach(asset => { %><option value="<%= asset.id %>" data-owner-id="<%= asset.assigned_user_id || '' %>" <%= String(values.asset_id) === String(asset.id) ? 'selected' : '' %>><%= asset.name %> · <%= asset.asset_number %></option><% }) %></select>
      </label>
    </div>
    <div class="portal-request-actions"><button class="button button-primary" type="submit">Absenden</button></div>
  </section>
</form>
<% } else { %>
<header class="workbench-heading">
  <div><h1>Ticket erstellen</h1></div>
  <a class="button button-secondary" href="/tickets">Zurück</a>
</header>

<form class="editor-grid" action="/tickets" method="post">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <section class="panel form-panel">
    <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
    <div class="form-grid">
      <label class="field-full">Betreff<input type="text" name="subject" value="<%= values.subject || '' %>" minlength="4" maxlength="180" placeholder="Worum geht es?" required autofocus></label>
      <label class="field-full">Beschreibung<textarea name="description" rows="9" minlength="10" placeholder="Problem und gewünschtes Ergebnis" required><%= values.description || '' %></textarea></label>
      <label>Queue<select name="category" data-queue-select><% queueRecords.forEach(queue => { %><option value="<%= queue.name %>" data-default-sla="<%= queue.default_sla_code || '' %>" <%= (values.category || queues[0]) === queue.name ? 'selected' : '' %>><%= queue.parent_name ? `${queue.parent_name} / ` : '' %><%= queue.name %></option><% }) %></select></label>
      <label>Kanal<select name="channel" required><% ticketChannels.forEach(item => { %><option value="<%= item.value %>" <%= (values.channel || 'email') === item.value ? 'selected' : '' %>><%= item.label %></option><% }) %></select></label>
    </div>
    <details class="form-disclosure">
      <summary>Weitere Angaben</summary>
      <div class="form-grid">
        <label>Ticketart<select name="ticket_type"><% ticketTypes.forEach(value => { %><option value="<%= value %>" <%= (values.ticket_type || ticketTypes[0]) === value ? 'selected' : '' %>><%= value %></option><% }) %></select></label>
        <label>Priorität<select name="priority"><% ['low','normal','high','urgent'].forEach(value => { %><option value="<%= value %>" <%= (values.priority || 'normal') === value ? 'selected' : '' %>><%= priorityLabel(value) %></option><% }) %></select></label>
        <label class="field-full">SLA<select name="sla" data-sla-select><% slaOptions.forEach(option => { %><option value="<%= option.value %>" <%= (values.sla || 'standard') === option.value ? 'selected' : '' %>><%= option.label %> · <%= option.responseMinutes / 60 %> h / <%= option.resolutionMinutes / 60 %> h</option><% }) %></select></label>
      </div>
    </details>
  </section>
  <aside class="panel form-panel ticket-create-aside">
    <div class="panel-header"><div><h2>Zuordnung</h2></div></div>
    <% if (can('tickets.manage')) { %>
      <label>Anfragende Person<select name="requester_id" data-ticket-requester><option value="" data-label="Ich selbst">Ich selbst</option><% requesters.forEach(person => { %><option value="<%= person.id %>" <%= String(values.requester_id) === String(person.id) ? 'selected' : '' %>><%= person.name %> · <%= person.customer_name || person.email %></option><% }) %></select></label>
      <label>Bearbeiter<select name="assignee_id"><option value="">Nicht zugewiesen</option><% agents.forEach(agent => { %><option value="<%= agent.id %>" <%= String(values.assignee_id) === String(agent.id) ? 'selected' : '' %>><%= agent.name %></option><% }) %></select></label>
    <% } else { %>
      <div class="info-box"><span class="avatar avatar-soft"><%= initials(currentUser.name) %></span><div><strong><%= currentUser.name %></strong><small>Du wirst als anfragende Person eingetragen.</small></div></div>
    <% } %>
    <label>Ressource
      <select name="asset_id" data-ticket-asset data-default-requester="<%= currentUser.id %>">
        <option value="">Keine Ressource verknüpfen</option>
        <% assets.forEach(asset => { %><option value="<%= asset.id %>" data-owner-id="<%= asset.assigned_user_id || '' %>" <%= String(values.asset_id) === String(asset.id) ? 'selected' : '' %>><%= asset.asset_number %> · <%= asset.name %> (<%= asset.asset_type %>)</option><% }) %>
      </select>
    </label>
    <div class="form-actions-sticky"><button class="button button-primary button-full" type="submit">Ticket erstellen</button></div>
  </aside>
</form>
<% } %>
