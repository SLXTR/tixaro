<% layout('layout') -%>
<header class="workbench-heading dashboard-heading">
  <div><h1>Übersicht</h1></div>
</header>

<section class="stat-grid" aria-label="Ticket-Kennzahlen">
  <a class="stat-card" href="/tickets"><small>Tickets</small><strong><%= stats.total %></strong></a>
  <a class="stat-card" href="/tickets?status=open"><small>Neu</small><strong><%= stats.open %></strong></a>
  <a class="stat-card" href="/tickets?status=in_progress"><small>In Bearbeitung</small><strong><%= stats.in_progress %></strong></a>
  <a class="stat-card" href="/tickets?escalated=1"><small>Eskalationen</small><strong><%= stats.escalated %></strong></a>
</section>

<div class="dashboard-grid">
  <section class="panel panel-wide">
    <div class="panel-header"><div><h2>Aktuelle Tickets</h2></div><a href="/tickets">Alle Tickets</a></div>
    <%- include('partials/ticket-table', { tickets }) %>
  </section>
  <aside class="panel">
    <% if (can('tickets.view_all')) { %>
      <div class="panel-header"><div><h2>Queues</h2></div></div>
      <div class="queue-list">
        <% queues.forEach(queue => { %>
          <a class="queue-row" href="/tickets?queue=<%= encodeURIComponent(queue.queue) %>">
            <span><strong><%= queue.queue %></strong><small><%= queue.new_count %> neu · <%= queue.active_count %> offen</small></span>
            <b><%= queue.total %></b>
          </a>
        <% }) %>
        <% if (!queues.length) { %><p class="empty-small">Noch keine Tickets in Queues.</p><% } %>
      </div>
    <% } else { %>
      <div class="panel-header"><div><h2>Dein Status</h2></div></div>
      <div class="requester-summary">
        <div class="summary-ring"><strong><%= stats.completed %></strong><span>gelöst</span></div>
        <p><strong><%= stats.open + stats.in_progress + stats.waiting %></strong> deiner Tickets sind derzeit noch aktiv.</p>
        <a class="button button-secondary button-full" href="/tickets">Meine Tickets</a>
      </div>
    <% } %>
  </aside>
</div>
