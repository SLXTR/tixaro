<% layout('layout') -%>
<section class="login-card">
  <div class="login-brand">
    <img class="brand-mark brand-mark-large" src="/brand-logo" alt="">
    <div><strong><%= companyName %></strong><span>Service Desk</span></div>
  </div>
  <div class="login-copy">
    <h1>Anmelden</h1>
  </div>
  <% if (error) { %><div class="form-error" role="alert"><%= error %></div><% } %>
  <form class="stack-form" action="/login" method="post">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <label>E-Mail-Adresse<input type="email" name="email" value="<%= email %>" autocomplete="username" required autofocus></label>
    <label>Passwort<input type="password" name="password" autocomplete="current-password" required></label>
    <button class="button button-primary button-full" type="submit">Anmelden</button>
  </form>
</section>
