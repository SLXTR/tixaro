# Wird durch `sh install.sh` automatisch erzeugt.
POSTGRES_PASSWORD=hier-ein-zufaelliges-internes-passwort
APP_BASE_URL=https://tickets.example.com
TIXARO_PROXY_NETWORK=tixaro_proxy
TIXARO_SERVER_NAME=tickets.example.com
TIXARO_DEPLOYMENT_MODE=

# Optional: bei mehreren erkannten Reverse-Proxys den gewünschten Container festlegen
TIXARO_PROXY_CONTAINER=

# Nur für die automatische Ausweichlösung mit Host- oder mitgeliefertem Nginx
APP_PORT=
TIXARO_HTTP_BIND=0.0.0.0
TIXARO_HTTP_PORT=

# Optional bei Betrieb hinter einem Reverse Proxy
TRUST_PROXY=1

# Optionale Integrationen und abweichende Infrastruktur
ADDRESS_SEARCH_URL=https://photon.komoot.io/api/
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
TIXARO_UPDATE_REMOTE=origin
TIXARO_GITHUB_TOKEN=
TIXARO_UPDATE_AUTO_RESTART=true
