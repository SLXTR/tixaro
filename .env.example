# Öffentlicher Name im Portal
COMPANY_NAME=Meine Firma

# Einmaliges Administratorkonto
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Bitte-ein-sicheres-Passwort-waehlen

# Mit `openssl rand -hex 32` erzeugen
SESSION_SECRET=hier-einen-zufaelligen-wert-mit-mindestens-32-zeichen-eintragen

# Extern erreichbarer lokaler Port (Nginx leitet später hierhin weiter)
APP_PORT=3000

# Datenbankwerte nur ändern, wenn die DATABASE_URL ebenfalls angepasst wird
POSTGRES_DB=tixaro
POSTGRES_USER=tixaro
POSTGRES_PASSWORD=Bitte-ein-separates-Datenbankpasswort-waehlen
DATABASE_URL=postgresql://tixaro:Bitte-ein-separates-Datenbankpasswort-waehlen@db:5432/tixaro

NODE_ENV=production
TRUST_PROXY=1
