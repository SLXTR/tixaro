# Öffentlicher Name im Portal
COMPANY_NAME=Tixaro

# Einmaliges Administratorkonto
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Bitte-ein-sicheres-Passwort-waehlen

# Mit `openssl rand -hex 32` erzeugen
SESSION_SECRET=hier-einen-zufaelligen-wert-mit-mindestens-32-zeichen-eintragen

# Extern erreichbarer lokaler Port (Nginx leitet später hierhin weiter)
APP_PORT=3000
APP_BASE_URL=https://tickets.example.com

# Datenbankwerte nur ändern, wenn die DATABASE_URL ebenfalls angepasst wird
POSTGRES_DB=tixaro
POSTGRES_USER=tixaro
POSTGRES_PASSWORD=Bitte-ein-separates-Datenbankpasswort-waehlen
DATABASE_URL=postgresql://tixaro:Bitte-ein-separates-Datenbankpasswort-waehlen@db:5432/tixaro

NODE_ENV=production
TRUST_PROXY=1

# Optional: eigener Photon-Endpunkt für Adressvorschläge
ADDRESS_SEARCH_URL=https://photon.komoot.io/api/
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# Separater Schlüssel für verschlüsselte Mail-Zugangsdaten, empfohlen: openssl rand -hex 32
MAIL_SECRET_KEY=hier-einen-weiteren-zufaelligen-wert-eintragen

# Optional für das Admin-Update-Center bei einer Git-Installation
TIXARO_UPDATE_REMOTE=origin
# Optional für private GitHub-Repositorys (nur Leserechte auf Inhalte)
TIXARO_GITHUB_TOKEN=
TIXARO_UPDATE_AUTO_RESTART=true
